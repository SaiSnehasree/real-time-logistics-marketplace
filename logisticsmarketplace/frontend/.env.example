# =============================================================================
# LogiFlow — Environment Configuration Template
# =============================================================================
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
# =============================================================================

# ─── Frontend (Vite) ──────────────────────────────────────────────────────────
# The base URL of the Spring Boot backend API (no trailing slash).
VITE_API_URL=http://localhost:8080

# ─── Backend (Spring Boot / application.properties) ──────────────────────────
# PostgreSQL connection
DB_URL=jdbc:postgresql://localhost:5432/logistics_db
DB_USERNAME=postgres
DB_PASSWORD=your_password_here

# JWT secret — must be at least 32 characters (Base64-encoded recommended)
JWT_SECRET=TXlTdXBlclNlY3JldEtleUZvckp3dEF1dGhlbnRpY2F0aW9uMTIzNDU2Nzg5MDEyMzQ1Ng==

# JWT token validity in milliseconds (default: 86400000 = 24 hours)
JWT_EXPIRATION_MS=86400000

# CORS — origins that are allowed to connect to the backend
# Separate multiple origins with commas
CORS_ALLOWED_ORIGINS=http://localhost:5173
